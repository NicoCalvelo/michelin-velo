rules_version='2'

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ────────────────────────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function isCurrentUser(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuthenticated() && getUserData().role == 'admin';
    }

    // ── Users /users/{userId} ──────────────────────────────────────────────────
    match /users/{userId} {
      // Lecture : l'utilisateur lui-même ou un admin
      allow read: if isCurrentUser(userId) || isAdmin();

      // Création : uniquement par l'utilisateur lui-même (lors de l'inscription)
      allow create: if isCurrentUser(userId)
                    && request.resource.data.role == 'user'; // force le rôle user à la création

      // Mise à jour : l'utilisateur peut modifier ses propres champs,
      // mais seul un admin peut changer le champ `role`
      allow update: if isCurrentUser(userId)
                       && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']))
                    || isAdmin();

      // Suppression : admin uniquement
      allow delete: if isAdmin();
    }

    // ── Products /products/{productId} ────────────────────────────────────────
    match /products/{productId} {
      // Lecture publique (même non connecté)
      allow read: if true;

      // Création, mise à jour, suppression : admin uniquement
      allow create, update, delete: if isAdmin();
    }

    // ── Experiences /experiences/{productId} ────────────────────────────────
    match /experiences/{productId} {
      // Lecture publique uniquement si publié, admin autorisé sur tout
      allow read: if resource.data.isPublished == true || isAdmin();

      // Ecriture admin uniquement, avec cohérence de l'identifiant produit
      allow create: if isAdmin()
                    && request.resource.data.productId == productId;

      allow update: if isAdmin()
                    && request.resource.data.productId == productId;

      allow delete: if isAdmin();
    }

    // ── Orders /orders/{orderId} ──────────────────────────────────────────────
    match /orders/{orderId} {
      // Lecture : propriétaire de la commande ou admin
      allow read: if isAuthenticated()
                  && (resource.data.userId == request.auth.uid || isAdmin());

      // Création : utilisateur connecté, pour lui-même uniquement
      allow create: if isAuthenticated()
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.status == 'pending'
                    && request.resource.data.paymentStatus == 'pending';

      // Mise à jour : propriétaire (commande pending uniquement, champs restreints)
      //               ou admin (tous les champs)
      allow update: if isAdmin()
                    || (isAuthenticated()
                        && resource.data.userId == request.auth.uid
                        && resource.data.status == 'pending'
                        && !request.resource.data.diff(resource.data).affectedKeys()
                            .hasAny(['userId', 'userEmail', 'items', 'subtotal',
                                     'shippingCost', 'total', 'paymentStatus', 'createdAt']));

      // Suppression : admin uniquement
      allow delete: if isAdmin();
    }

    // ── Carts /carts/{userId} ─────────────────────────────────────────────────
    match /carts/{userId} {
      // Lecture, écriture, suppression : l'utilisateur lui-même ou un admin
      allow read, write, delete: if isCurrentUser(userId) || isAdmin();
    }

    // ── Reviews /reviews/{reviewId} ───────────────────────────────────────────
    match /reviews/{reviewId} {
      // Lecture publique
      allow read: if true;

      // Création : utilisateur connecté, pour lui-même uniquement
      allow create: if isAuthenticated()
                    && request.resource.data.userId == request.auth.uid;

      // Mise à jour : admin uniquement
      allow update: if isAdmin();

      // Suppression : auteur ou admin
      allow delete: if (isAuthenticated() && resource.data.userId == request.auth.uid)
                    || isAdmin();
    }
  }
}

